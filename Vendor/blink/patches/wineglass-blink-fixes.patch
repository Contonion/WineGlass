=== blink/modrm.c — GetMmxAddress (replace the 3-line GetVectorAddress(A,8) version) ===
// x86 MMX m64 memory operands are NOT alignment-restricted (unlike 16-byte SSE).
// GetVectorAddress's (v & 7) check wrongly faults unaligned m64 (OpenSSL MMX bn_mul
// uses e.g. [esp+0x14]). Allow unaligned within a page; keep page-straddle safety.
u8 *GetMmxAddress(P) {
  // MMX m64 memory operands are NOT alignment-restricted on x86 (unlike 16-byte
  // SSE operands). GetVectorAddress's (v & 7) check wrongly faults on unaligned
  // m64 (e.g. OpenSSL's MMX bignum uses [esp+0x14]). Allow unaligned access as
  // long as the 8 bytes stay within one page (preserves page-straddle safety).
  u8 *p;
  i64 v;
  if (IsModrmRegister(rde)) {
    return XmmRexbRm(m, rde);
  }
  v = ComputeAddress(A);
  SetReadAddr(m, v, 8);
  if ((v & 4095) > 4096 - 8 || !(p = LookupAddress(m, v))) {
    ThrowSegmentationFault(m, v);
  }
  return p;
}
